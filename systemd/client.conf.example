# mqvpn client configuration
# Copy to /etc/mqvpn/client-<name>.conf and edit as needed.
# Start with: systemctl start mqvpn-client@<name>

[Server]
Address = your-server.example.com:443
# Insecure = false

[TLS]
# Cipher = TLS_AES_128_GCM_SHA256:TLS_CHACHA20_POLY1305_SHA256

[Auth]
Key = <YOUR_PSK_HERE>
# Username = <YOUR_USERNAME>   # optional: identifies this client on the server (shown in status/logs)

[Interface]
TunName = mqvpn0
DNS = 1.1.1.1, 8.8.8.8
LogLevel = info
# MTU = 1280                   # TUN MTU (1280–9000, default: auto = ~1382)
# KillSwitch = false
# NoRoutes = false         # set to true on router/embedded integrations to keep host routes untouched
# Reconnect = true
# ReconnectInterval = 5
# RouteViaServer = false   # add a host route to the server IP before setting the default route

[Control]
# Port = 9091          # enable JSON control API on this TCP port
# Addr = 127.0.0.1     # bind address (default: 127.0.0.1, loopback only)

[Multipath]
# Scheduler: minrtt|wlb|wlb_udp_pin|wrtt|backup_fec|rap (default: wlb)
# wrtt = weighted RTT aggregation; adjust per-path weights at runtime via set_path_weight control API
Scheduler = wlb
# CC = bbr2             # bbr2|bbr|cubic|new_reno|copa|unlimited (default bbr2)
# ReinjectionControl = true
# ReinjectionMode = default   # default|deadline|dgram
# FecEnable = true
# FecScheme = reed_solomon    # galois_calculation|packet_mask|reed_solomon|xor
# Path = eth0
# Path = wlan0
# BackupPath = lte0   # failover-only: used only when all primary paths are down

# [Reorder]
# Enabled = off              # on|off — reorder buffer for inner UDP (off by default)
# MaxWaitMs = 30             # max hold time before releasing a gap (ms)
# CapPackets = 1024          # max buffered datagrams per flow (power of two)

# [ReorderRule]              # bulk inner QUIC: reorder on
# Proto = udp
# Port = 443
# Profile = fiber_lte        # cellular_bond|fiber_lte|quic_bulk|default_udp (pass-through)

# [ReorderRule]              # DNS: never delay
# Proto = udp
# Port = 53
# Profile = default_udp
