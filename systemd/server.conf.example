# mqvpn server configuration
# Copy to /etc/mqvpn/server.conf and edit as needed.

[Interface]
Listen = 0.0.0.0:443
Subnet = 10.0.0.0/24
# Subnet6 = fd00:abcd::/112
TunName = mqvpn0
LogLevel = info
# MTU = 1280                   # TUN MTU (1280–9000, default: auto = ~1382)

[TLS]
Cert = /etc/mqvpn/server.crt
Key = /etc/mqvpn/server.key
# Cipher = TLS_AES_128_GCM_SHA256:TLS_AES_256_GCM_SHA384

[Auth]
# Generate with: mqvpn --genkey
Key = <YOUR_PSK_HERE>
MaxClients = 64
# Per-user credentials: User = name:key
#   Optional fixed IP:  User = name:key:x.x.x.x
#   The fixed address is permanently reserved — not available to other clients.
# User = alice:alice-secret
# User = bob:bob-secret
# User = carol:carol-secret:10.0.0.50

[Control]
# ControlPort = 9090          # enable JSON control API on this TCP port
# ControlAddr = 127.0.0.1     # bind address (default: 127.0.0.1, loopback only)

[Multipath]
# Scheduler: minrtt|wlb|wlb_udp_pin|wrtt|backup_fec|rap
# wrtt = weighted RTT aggregation; adjust per-path weights at runtime via set_path_weight control API
Scheduler = wlb
# CC = bbr2             # bbr2|bbr|cubic|new_reno|copa|unlimited (default bbr2)
# ReinjectionControl = true
# ReinjectionMode = default   # default|deadline|dgram
# FecEnable = true
# FecScheme = reed_solomon    # galois_calculation|packet_mask|reed_solomon|xor

# [Reorder]
# Enabled = off              # on|off — reorder buffer for inner UDP (off by default)
# MaxWaitMs = 30             # max hold time before releasing a gap (ms)
# CapPackets = 1024          # max buffered datagrams per flow (power of two)

# [ReorderRule]              # bulk inner QUIC: reorder on
# Proto = udp
# Port = 443
# Profile = fiber_lte        # cellular_bond|fiber_lte|quic_bulk|default_udp (pass-through)

# [ReorderRule]              # DNS: never delay
# Proto = udp
# Port = 53
# Profile = default_udp

# [Control]
# Local-only TCP control/admin API (add/remove users, query stats).
# Uncomment to enable. No authentication — bind 127.0.0.1 only unless you
# place it behind a reverse proxy / SSH tunnel / firewall.
# Listen = 127.0.0.1:9090
