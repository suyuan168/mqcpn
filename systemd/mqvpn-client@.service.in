[Unit]
Description=mqvpn VPN Client (%i)
After=network-online.target
Wants=network-online.target
Documentation=https://github.com/mp0rta/mqvpn
StartLimitIntervalSec=60
StartLimitBurst=3

[Service]
Type=simple
ExecStartPre=-/usr/bin/touch /etc/resolv.conf.mqvpn.bak
ExecStart=@CMAKE_INSTALL_PREFIX@/bin/mqvpn --config /etc/mqvpn/client-%i.conf
Restart=on-failure
RestartSec=5

# Security hardening
ProtectHome=true
ProtectSystem=strict
PrivateTmp=true
NoNewPrivileges=yes
# Note: ProtectKernelTunables=yes is NOT set because the client writes to
# /proc/sys/net/ipv6/conf/*/disable_ipv6 for IPv6 tunnel setup.
ProtectKernelModules=yes
ProtectControlGroups=yes
RestrictSUIDSGID=yes
ReadOnlyPaths=/etc/mqvpn
ReadWritePaths=/dev/net/tun /etc/resolv.conf /etc/resolv.conf.mqvpn.bak

[Install]
WantedBy=multi-user.target
