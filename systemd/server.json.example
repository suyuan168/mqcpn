{
  "mode": "server",
  "listen": "0.0.0.0:443",
  "subnet": "10.0.0.0/24",
  "subnet6": "fd00:abcd::/112",
  "tun_name": "mqvpn0",
  "log_level": "info",
  "cert_file": "/etc/mqvpn/server.crt",
  "key_file": "/etc/mqvpn/server.key",
  "cipher": "TLS_AES_128_GCM_SHA256:TLS_AES_256_GCM_SHA384",
  "auth_key": "<YOUR_PSK_HERE>",
  "users": [
    { "name": "alice", "key": "<ALICE_PSK_HERE>" },
    { "name": "carol", "key": "<CAROL_PSK_HERE>", "fixed_ip": "10.0.0.50" },
    "bob:<BOB_PSK_HERE>"
  ],
  "max_clients": 64,
  "scheduler": "wlb",
  "mtu": 0,
  "cc": "bbr2",
  "reinjection_control": true,
  "reinjection_mode": "default",
  "fec_enable": true,
  "fec_scheme": "reed_solomon",
  "control_port": 0,
  "control_addr": "127.0.0.1",
  "hybrid": {
    "enabled": false,
    "tcp": "auto",
    "tcp_max_flows": 256,
    "tcp_max_global_flows": 1024,
    "tcp_idle_timeout_sec": 300,
    "tcp_connect_timeout_sec": 10,
    "egress_allow": [],
    "egress_deny": []
  },
  "reorder": {
    "enabled": "off",
    "max_wait_ms": 30,
    "cap_packets": 1024
  },
  "reorder_rules": [
    { "proto": "udp", "port": 443, "profile": "fiber_lte" },
    { "proto": "udp", "port": 53,  "profile": "default_udp" }
  ]
}
